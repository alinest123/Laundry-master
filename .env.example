# ─────────────────────────────────────────────────────────────
# THE SCIENCE OF PROFESSIONAL TEXTILE CARE — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL=

# ── Auth / Sessions ───────────────────────────────────────────
# Strong random secret for signing session cookies (min 32 chars)
SESSION_SECRET=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Example: https://laundry-master.com,https://www.laundry-master.com
ALLOWED_ORIGINS=

# ── Stripe Payments ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Zoom Integration ──────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# ── Email ─────────────────────────────────────────────────────
EMAIL_API_KEY=
EMAIL_FROM=

# ── Analytics ─────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=

# ── Vercel / Deployment ───────────────────────────────────────
# Set automatically by Vercel — do not set manually.
# VERCEL_URL=
# NODE_ENV=production

# ── Vite (frontend build) ─────────────────────────────────────
# Base path for the frontend. Set to "/" for root deployments (Vercel).
# On Replit this is set to the artifact sub-path automatically.
BASE_PATH=/
